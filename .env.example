# ── Server ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/shaadi_baazaar

# Startup DB automation:
# DB_SEED_IN_DEV=true seeds automatically in development only when vendors table is empty
# DB_SEED_ON_START=true forces seeding on every server start (useful for demos)
DB_SEED_IN_DEV=true
DB_SEED_ON_START=false

# Cloud (Render / Railway / Supabase / Neon) — paste the full URL:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────
# Local frontend:
CLIENT_URL=http://localhost:5173
# Production (comma-separated, no spaces):
# CLIENT_URL=https://shaadibaazaar.vercel.app,https://www.shaadibaazaar.in
